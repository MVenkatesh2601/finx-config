{
  "known_patterns": [
    {
      "id": "HDFC_CC_SPEND_UPI",
      "identityType": "CREDIT_CARD",
      "intent": "SWIPE",
      "regex": "Txn Rs\\.?\\s?(?<amount>[\\d,]+(\\.\\d+)?)\\s*On HDFC (Bank )?Card\\s?(?<last4>\\d{4})\\s*At\\s?(?<merchant>[A-Za-z0-9@._-]+)\\sby\\sUPI\\s(?<ref>\\d+)\\s?On\\s?(?<date>\\d{2}-\\d{2})"
    },
    {
      "id": "HDFC_BANK_DEBIT_SENT_UPI",
      "identityType": "BANK",
      "intent": "DEBIT",
      "regex": "(?i)Sent Rs\\.? ?(?<amount>[\\d.,]+)[\\s\\S]*?From HDFC Bank A\\/C \\*?(?<last4>\\d{3,4})[\\s\\S]*?To (?<merchant>[A-Za-z\\s]*)(?=on)on\\s?(?<date>\\d{2}[-\\/]\\d{2}[-\\/]\\d{2})\\s?ref\\s?(?<ref>\\d+)"
    },
    {
      "id": "GENERIC_CREDIT_CARD_SWIPE",
      "identityType": "CREDIT_CARD",
      "intent": "SWIPE",
      "regex": "(?i)(?:inr|rs).?\\s?(?<amount>[.,\\d]+)\\s?spent\\s?on\\s?.*card\\s?(ending\\swith\\s)?x{0,4}(?<last4>\\d{4})\\s?at\\s?(?<merchant>.*)(?=on)on\\s?(?<date>\\d{2,4}-\\d{2}-\\d{2,4})"
    },
    {
      "id": "HDFC_CC_PAYMENT",
      "identityType": "CREDIT_CARD",
      "intent": "PAYMENT",
      "systemCategory": "CREDIT_CARD_PAYMENT",
      "regex": "(?i)Payment of Rs (?<amount>[\\d,]+(\\.\\d+)?) was credited to your card ending (?<last4>\\d{4})\\s?on\\s?(?<date>\\d{1,2}\\/([a-z]{3}|\\d{2})\\/\\d{2,4})"
    },
    {
      "id": "HDFC_BANK_CREDIT_FROM_VPA",
      "identityType": "BANK",
      "intent": "CREDIT",
      "regex": "(?i)Rs.?\\s?(?<amount>\\d+\\.\\d{2}?)\\s+credited\\s+to\\s+.*\\s+Bank\\s+.*X+(?<last4>\\d{3,6})\\s?on\\s?(?<date>\\d{1,2}-\\d{1,2}-\\d{2,4})\\s?from.* (?<merchant>.*@.[^\\s]*).*(?<=UPI)\\s?(?<ref>\\d+)"
    },
    {
      "id": "HDFC_ACCOUNT_NEFT_DEPOSIT",
      "identityType": "BANK",
      "intent": "CREDIT",
      "regex": "(?i)INR\\s*(?<amount>[\\d,]+(\\.\\d+)?)\\s?deposited.*X{2,6}(?<last4>\\d{4})\\s?on\\s?(?<date>\\d{2}-[a-z]{3}-\\d{2,4}).*NEFT\\s*Cr-[a-zA-Z0-9]*-(?<merchant>.[^-]*)"
    },
    {
      "id": "HDFC_BANK_IMPS_CREDIT",
      "identityType": "BANK",
      "intent": "CREDIT",
      "regex": "(?i)(Received|Credited)!?\\s*(INR|Rs)\\.?\\s*(?<amount>[\\d.,]+)\\s*in\\s*HDFC Bank\\s*(Account|Acct|Act|A\\/c)\\s*(xx{1,5})(?<last4>\\d{3,4})\\s*on[:\\s]*(?<date>\\d{2}[-/](\\d{2}|\\D{3})[-/]\\d{2})\\s*For\\s*IMPS\\s*-\\s*(?<merchant>.*?)-\\s*(?<ref>\\d{6,15})"
    },
    {
      "id": "ICICI_CC_SPEND",
      "identityType": "CREDIT_CARD",
      "intent": "SWIPE",
      "regex": "(?i)(?:INR|Rs)\\s?(?<amount>[\\d,]+(\\.\\d+)?) spent (?:using|on) .* Bank Card .*?(?<last4>\\d{4})\\s?on\\s?(?<date>\\d{1,2}-(?:[a-z]{3}|\\d{2})-\\d{2,4})\\s?(?:on|at)\\s? (?<merchant>[^.]+)"
    },
    {
      "id": "ICICI_CC_PAYMENT",
      "identityType": "CREDIT_CARD",
      "intent": "PAYMENT",
      "systemCategory": "CREDIT_CARD_PAYMENT",
      "regex": "(?i)Payment of (?:Rs|INR) (?<amount>[\\d,]+(?:\\.\\d+)?) has been received on your .* Bank Credit Card .*?(?<last4>\\d{4})\\s?on\\s?(?<date>\\d{1,2}-(?:[a-z]{3}|\\d{2})-\\d{2,4})"
    },
    {
      "id": "ICICI_BANK_DEBIT_UPI",
      "identityType": "BANK",
      "intent": "DEBIT",
      "regex": "(?i).*Bank Acct (?:XX|X|\\*)?(?<last4>\\d{3,4}) debited for Rs\\.? ?(?<amount>[\\d.,]+)\\s?on\\s?(?<date>\\d{1,2}-(?:[a-z]{3}|\\d{2})-\\d{2,4});?\\s?(?<merchant>[A-Za-z0-9 .]+) credited.?\\s?UPI:\\s?(?<ref>\\d+)"
    },
    {
      "id": "ICICI_BANK_CREDIT_IMPS",
      "identityType": "BANK",
      "intent": "CREDIT",
      "regex": "(?i)ICICI Bank Account (?:XX|X|\\*)?(?<last4>\\d{3,4}) is credited with Rs\\.? ?(?<amount>[\\d.,]+)\\s?on\\s?(?<date>\\d{1,2}-(?:[a-z]{3}|\\d{2})-\\d{2,4})"
    },
    {
      "id": "ICICI_BANK_DEBIT_IMPS",
      "identityType": "BANK",
      "intent": "DEBIT",
      "regex": "(?i)ICICI Bank (?:Account|Acct|Act)\\s?(XX|X|\\\\*)?(?<last4>\\d{3,4})\\s?debited\\s?with\\s?(?:Rs|INR)\\.?\\s?(?<amount>[\\d.,]+)\\s?on\\s?(?<date>\\d{2}-(\\d{2}|\\D{3})-\\d{2}).*IMPS:(?<ref>\\d+)"
    },
    {
      "id": "PLUXEE_MEAL_CARD_SWIPE",
      "identityType": "CREDIT_CARD",
      "intent": "SWIPE",
      "regex": "(?i)rs\\.?\\s?(?<amount>[\\d,]+(?:\\.\\d+)?)\\s+spent\\s+from\\s+pluxee\\s+meal\\s+card(?:.*?x{2,8}(?<last4>\\d{4}))?.*?at\\s+(?<merchant>[^.]+)"
    },
    {
      "id": "GENERIC_BANK_DEBIT_IMPS",
      "identityType": "BANK",
      "intent": "DEBIT",
      "regex": "(?i)(?:a\\/c|acct|account)\\s*(?:x+)?(?<last4>\\d{3,6}).*?debit:?\\s*rs\\.?\\s?(?<amount>[\\d,]+(?:\\.\\d+)?).*?(?:to\\s(?<merchant>[^.]+))?"
    },
    {
      "id": "CC_PAYMENT_BASIC",
      "identityType": "CREDIT_CARD",
      "intent": "PAYMENT",
      "systemCategory": "CREDIT_CARD_PAYMENT",
      "regex": "payment\\s+of\\s+rs\\.?\\s*(?<amount>[\\d,]+).*card\\s+ending\\s+with\\s+(?<last4>\\d{4}).*?(?<date>\\d{1,2}-\\d{1,2}-\\d{4})"
    },
    {
      "id": "CC_PAYMENT_RECEIVED",
      "identityType": "CREDIT_CARD",
      "intent": "PAYMENT",
      "systemCategory": "CREDIT_CARD_PAYMENT",
      "regex": "payment\\s+of\\s+rs\\s+(?<amount>(?:\\d{1,3}(?:,\\d{3})*|\\d+)\\.\\d{2}).*received\\s+on\\s+your\\s+.*card\\s+x{2,8}(?<last4>\\d{4}).*?(?<date>\\d{1,2}-(?:[0-9]{1,2}|[a-zA-Z]{3})-\\d{2,4})"
    },
    {
      "id": "HDFC_CC_PAYMENT_EXTENDED",
      "identityType": "CREDIT_CARD",
      "intent": "PAYMENT",
      "systemCategory": "CREDIT_CARD_PAYMENT",
      "regex": "(?i)payment\\s+of\\s+rs\\.?\\s*(?<amount>[\\d,]+(?:\\.\\d+)?)\\s+was\\s+credited\\s+to\\s+your\\s+card\\s+ending\\s+(?<last4>\\d{4})"
    },
    {
      "id": "GENERIC_CC_PAYMENT",
      "identityType": "CREDIT_CARD",
      "intent": "PAYMENT",
      "systemCategory": "CREDIT_CARD_PAYMENT",
      "regex": "(?i)payment\\s*of\\s*(?:inr|rs)\\.?\\s*(?<amount>[,.\\d]+)\\s*.*(received|credited)\\son\\s*.*(account|acct|acc|ac|a\\/c)\\s*(\\d+)?(x+)?(?<last4>\\d{3,7})\\s*on\\s*(?<date>\\d{1,2}-\\D{3}-\\d{2,4})"
    }

  ],
  "bill_patterns": [
    {
      "id": "LIC_PREMIUM_REMINDER",
      "billType": "INSURANCE",
      "regex": "(?i)(?=.*policy\\s*no\\.?\\s*(?<ref>\\d+))(?=.*premium).*?(?:rs\\.?\\s*\\*+|\\*+)(?<amount>[0-9]+(?:\\.[0-9]{2})?).*?(?:pay\\s+on\\s+or\\s+before|due\\s+on)\\s*(?<date>\\d{1,2}\\/\\d{1,2}\\/\\d{2,4})"
    },
    {
      "id": "HDFC_LOAN_EMI_REMINDER",
      "billType": "LOAN",
      "regex": "(?i)emi\\s+reminder.*?loan\\s+a\\/c\\s*(?<ref>\\d+).*?emi\\s+of\\s+rs\\.?\\s*(?<amount>[\\d,]+(?:\\.\\d+)?)\\s+is\\s+due\\s+on\\s+(?<date>\\d{1,2}-[A-Za-z]{3}-\\d{2,4})"
    },
    {
      "id": "GENERIC_INSURANCE_PREMIUM_REMINDER",
      "billType": "INSURANCE",
      "regex": "(?i)pay\\s+premium\\s+of\\s+rs\\.?\\s*(?<amount>[\\d,]+(?:\\.\\d+)?)\\s+for\\s+policy\\s*(?<ref>[a-z0-9x]+).*?\\bby\\s*(?<date>\\d{1,2}-[a-z]{3}-\\d{2,4})"
    }


  ],
  "credit_card_statement_patterns": [
    {
      "id": "ICICI_CREDIT_CARD_BILL",
      "billType": "CREDIT_CARD",
      "regex": "(?i)pay\\s*total\\s*(?:amount\\s*due|due)\\s*of\\s*rs\\.?\\s*(?<total>[\\d,]+(?:\\.\\d{1,2})?)\\s*or\\s*minimum\\s*amount\\s*due\\s*of\\s*rs\\.?\\s*(?<min>[\\d,]+(?:\\.\\d{1,2})?)\\s*by\\s*(?<date>\\d{2}-[a-z]{3}-\\d{2,4})\\s*(?:towards|for)\\s*(?<name>[a-z ]+?credit\\s*card)\\s*xx(?<last4>\\d{4})"
    },
    {
      "id": "HDFC_CC_STATEMENT",
      "billType": "CREDIT_CARD",
      "regex": "(?i)credit\\s*card.*?(?<last4>\\d{4}).*?total\\s*due\\s*[:\\-]?\\s*rs\\.?\\s*(?<total>[\\d,]+(?:\\.\\d{1,2})?).*?min\\.?\\s*due\\s*[:\\-]?\\s*rs\\.?\\s*(?<min>[\\d,]+(?:\\.\\d{1,2})?).*?(?:pay\\s*by|due\\s*by)\\s*(?<date>\\d{2}[-/][a-z0-9]{2,3}[-/]\\d{2,4})"
    },
    {
      "id": "HDFC_CC_STATEMENT_ALT",
      "billType": "CREDIT_CARD",
      "regex": "(?i)amount\\s*due\\s*rs\\.?\\s*(?<total>[\\d,]+(?:\\.\\d{1,2})?).*?card\\s*(?<last4>\\d{4}).*?(?:by|on)\\s*(?<date>\\d{2}\\/[a-z]{3}\\/\\d{2,4})"
    },
    {
      "id": "ICICI_CC_STATEMENT_FLEX",
      "billType": "CREDIT_CARD",
      "regex": "(?i)credit\\s*card.*?(?:xx|xxxx)[^\\d]*(?<last4>\\d{4}).*?total\\s+of\\s+rs\\.?\\s*(?<total>[\\d,]+(?:\\.\\d{1,2})?).*?minimum\\s+of\\s+rs\\.?\\s*(?<min>[\\d,]+(?:\\.\\d{1,2})?).*?due\\s+by\\s+(?<date>\\d{2}-[a-z]{3}-\\d{2,4})"
    }

  ],
  "bill_payment_patterns": [
    {
      "id": "LIC_PAYMENT",
      "billType": "INSURANCE",
      "regex": "policy\\s*no\\.?\\s*(?<policy>\\d+).*[adjusted|paid]\\s?on\\s?(?<date>\\d{2}\\/\\d{2}\\/\\d{4})"
    }


  ],
  "investment_patterns": [
    {
      "id": "EPFO_PASSBOOK_UPDATE",
      "investmentType": "EPFO",
      "regex": "passbook balance.*?Rs?\\.?\\s?(?<balance>[\\d,]+).*?Contribution.*?Rs\\s?(?<amount>[\\d,]+).*?due month\\s?(?<period>[A-Za-z0-9-]+)"
    },
    {
      "id": "SSY_ACCOUNT_CREDIT",
      "investmentType": "SSY",
      "regex": "Account No\\.?\\s*(?<ref>[A-Za-z0-9*]+).*?credit.*?Rs?\\.?\\s?(?<amount>[\\d,]+).*?Balance.*?Rs?\\.?\\s?(?<balance>[\\d,]+)"
    }
  ]
}
